.DS_Store
.idea/

# Office lock files (created while data/current/*.xlsx is open in Excel)
~$*.xlsx

# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*

# environment variables
.env
.env.production

# pipeline output (regenerated from data/current/dictionary.xlsx on every build)
src/data/generated/

# local, machine-specific Claude Code permissions — not shared project config
.claude/settings.local.json

# scratch output (screenshots, previews) — never committed
.tmp/

# auto-mirrored copies of images shown via the Read tool
screenshots/

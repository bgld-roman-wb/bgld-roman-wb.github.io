---
import '../styles/global.css';
import Header from '../components/site/Header.astro';
import Footer from '../components/site/Footer.astro';
import { defaultLang, type Locale } from '../i18n/ui';

interface Props {
	title: string;
	description?: string;
	lang?: Locale;
	searchIndex?: boolean;
}

const { title, description, lang = defaultLang, searchIndex = true } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<script is:inline>
			// Runs before first paint to avoid a flash of the wrong theme. Light is the default —
			// this only ever adds data-theme="dark", matching a stored preference from ThemeToggle.
			try {
				if (localStorage.getItem('theme') === 'dark') {
					document.documentElement.dataset.theme = 'dark';
				}
			} catch (e) {}
		</script>
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		{description && <meta name="description" content={description} />}
		<title>{title} · Burgenland Roman Dictionary</title>
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<Header lang={lang} />
		<main id="main" data-pagefind-body={searchIndex ? true : undefined}>
			<div class="container" style="padding-block: var(--space-4);">
				<slot />
			</div>
		</main>
		<Footer lang={lang} />
		<script is:inline>
			// Hint bubbles open on focus (tap, on touch screens). On iOS, tapping elsewhere doesn't
			// reliably blur a focused non-input element, so the bubble could get stuck open — close it
			// on any tap outside, and let a second tap on the trigger itself toggle it off.
			document.addEventListener('pointerdown', (e) => {
				const active = document.activeElement;
				if (!(active instanceof HTMLElement) || !active.classList.contains('hint-trigger')) return;
				const tapped = e.target instanceof Element ? e.target.closest('.hint-trigger') : null;
				if (tapped === active) {
					e.preventDefault(); // a second tap would just refocus — toggle off instead
					active.blur();
				} else if (!tapped) {
					active.blur();
				}
			});
		</script>
	</body>
</html>

---
import '../styles/global.css';
import Header from '../components/site/Header.astro';
import Footer from '../components/site/Footer.astro';
import { defaultLang, type Locale } from '../i18n/ui';

interface Props {
	title: string;
	description?: string;
	lang?: Locale;
	searchIndex?: boolean;
}

const { title, description, lang = defaultLang, searchIndex = true } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		{description && <meta name="description" content={description} />}
		<title>{title} · Burgenland Roman Dictionary</title>
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<Header lang={lang} />
		<main id="main" class="container" style="padding-block: var(--space-4);" data-pagefind-body={searchIndex ? true : undefined}>
			<slot />
		</main>
		<Footer lang={lang} />
	</body>
</html>

---
import '../styles/global.css';
import Header from '../components/site/Header.astro';
import Footer from '../components/site/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'An online dictionary for Burgenland Roman.' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title} · Burgenland Roman Dictionary</title>
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<Header />
		<main id="main" class="container" style="padding-block: var(--space-4);">
			<slot />
		</main>
		<Footer />
	</body>
</html>

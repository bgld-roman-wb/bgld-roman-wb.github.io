---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Pagefind auto-detects each page's language from <html lang> and builds a separate index per
// language, so the UI loaded on a German page searches German entries and vice versa. We only
// localize the placeholder text here. The bundle is generated by the `pagefind` CLI post-build
// (see package.json), so the script 404s harmlessly in dev/preview before a full `npm run build`.
---

<div id="search"></div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline define:vars={{ placeholder: t('search.placeholder') }}>
	window.addEventListener('DOMContentLoaded', () => {
		if (window.PagefindUI) {
			new window.PagefindUI({
				element: '#search',
				showSubResults: true,
				translations: { placeholder },
				ranking: {
					pageLength: 0,
					termFrequency: 0,
				},
			});
		}
	});
</script>

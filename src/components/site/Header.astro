---
import SearchBox from './SearchBox.astro';
---

<header style="border-bottom: 1px solid var(--color-border);">
	<div class="container" style="display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3); padding-block: var(--space-3);">
		<p style="margin: 0; font-weight: 700;">
			<a href="/" style="color: inherit; text-decoration: none;">Burgenland Roman Dictionary</a>
		</p>
		<nav aria-label="Main" style="display: flex; gap: var(--space-3); margin-inline-start: auto;">
			<a href="/browse/alphabetical/a">Browse</a>
			<a href="/about">About</a>
		</nav>
		<div style="flex-basis: 100%;">
			<SearchBox />
		</div>
	</div>
</header>

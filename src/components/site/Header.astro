---
import SearchBox from './SearchBox.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Locale } from '../../i18n/ui';
import { localizePath, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header>
	<div class="container header-inner">
		<p class="site-title">
			<a href={localizePath('/', lang)} style="color: inherit; text-decoration: none;">{t('site.title')}</a>
		</p>
		<nav class="main-nav" aria-label="Main">
			<a href={localizePath('/browse/alphabetical/a', lang)}>{t('nav.browse')}</a>
			<a href={localizePath('/abbreviations', lang)}>{t('nav.abbreviations')}</a>
			<a href={localizePath('/about', lang)}>{t('nav.about')}</a>
			<LanguageSwitcher lang={lang} />
		</nav>
		<div class="search-row">
			<SearchBox lang={lang} />
		</div>
	</div>
</header>

<style>
	header {
		border-bottom: 1px solid var(--color-border);
	}
	.header-inner {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-3);
		padding-block: var(--space-3);
	}
	.site-title {
		margin: 0;
		font-weight: 700;
		min-width: 0;
	}
	.main-nav {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2) var(--space-3);
		margin-inline-start: auto;
		align-items: center;
		max-width: 100%;
		min-width: 0;
	}
	.search-row {
		flex-basis: 100%;
		min-width: 0;
	}
	@media (max-width: 40rem) {
		.site-title,
		.main-nav {
			flex-basis: 100%;
		}
		.main-nav {
			margin-inline-start: 0;
		}
	}
</style>

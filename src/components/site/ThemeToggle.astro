---
// A minimal light/dark switch. The initial data-theme is set synchronously in BaseLayout's
// <head> (before paint); this component just reflects and toggles that state, persisting the
// choice to localStorage. Light is always the default for first-time visitors.
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<button type="button" id="theme-toggle" class="theme-toggle" role="switch" aria-checked="false" aria-label={t('theme.toggle')} title={t('theme.toggle')}>
	<span class="track">
		<svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
			<circle cx="12" cy="12" r="4" />
			<path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
		</svg>
		<svg class="icon icon-moon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
			<path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a7 7 0 1 0 10.5 10.5Z" />
		</svg>
		<span class="thumb"></span>
	</span>
</button>

<style>
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		color: var(--color-muted);
	}
	.track {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		inline-size: 2.5rem;
		block-size: 1.375rem;
		padding-inline: 0.25rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-surface);
	}
	.theme-toggle:hover .track {
		border-color: var(--color-accent);
	}
	.icon {
		position: relative;
		inline-size: 0.75rem;
		block-size: 0.75rem;
		flex-shrink: 0;
	}
	.thumb {
		position: absolute;
		inset-block: 1px;
		inset-inline-start: 1px;
		inline-size: 1.125rem;
		block-size: 1.125rem;
		border-radius: 50%;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		transition: transform 0.15s ease;
	}
	.theme-toggle[aria-checked='true'] .thumb {
		transform: translateX(1.125rem);
	}
</style>

<script is:inline>
	(function () {
		var btn = document.getElementById('theme-toggle');
		if (!btn) return;
		var root = document.documentElement;
		function sync() {
			btn.setAttribute('aria-checked', String(root.dataset.theme === 'dark'));
		}
		sync();
		btn.addEventListener('click', function () {
			if (root.dataset.theme === 'dark') {
				delete root.dataset.theme;
				try {
					localStorage.setItem('theme', 'light');
				} catch (e) {}
			} else {
				root.dataset.theme = 'dark';
				try {
					localStorage.setItem('theme', 'dark');
				} catch (e) {}
			}
			sync();
		});
	})();
</script>

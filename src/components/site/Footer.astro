---
import type { Locale } from '../../i18n/ui';
import { localizePath, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Federal funding acknowledgment required alongside the BKA logo; both link to the same
// government page as in the sibling project. Logo swaps by locale (German/English wordmark).
const volksgruppenLink = 'https://www.bundeskanzleramt.gv.at/themen/volksgruppen.html';
const bkaLogo = lang === 'de' ? '/bka-logo-de.svg' : '/bka-logo-en.svg';
---

<footer class="site-footer" data-pagefind-ignore>
	<div class="container footer-inner">
		<div class="footer-links">
			<a href={volksgruppenLink} target="_blank" rel="noopener" class="bka-logo-link" role="img" aria-label={t('footer.minorityPromotion')} style={`background-image: url(${bkaLogo});`}>
			</a>
			<a href={localizePath('/impressum', lang)}>{t('footer.imprint')}</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--color-border);
		margin-top: var(--space-5);
	}
	.footer-inner {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding-block: var(--space-3);
		color: var(--color-muted);
		font-size: 0.9em;
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3);
	}
	.footer-links a {
		color: var(--color-muted);
	}
	.footer-links a:hover {
		color: var(--color-text);
	}
	.bka-logo-link {
		display: inline-block;
		inline-size: 8rem;
		block-size: 2rem;
		background-repeat: no-repeat;
		background-position: left center;
		background-size: contain;
	}
	/* The logo's wordmark is drawn in plain black with no dark-mode variant of its own — invert
	   it so the text stays legible, then hue-rotate back to keep the brand's orange stripe close
	   to its original color instead of an inverted cyan. */
	:global([data-theme='dark']) .bka-logo-link {
		filter: invert(1) hue-rotate(180deg);
	}
</style>

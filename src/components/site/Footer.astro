---
import type { Locale } from '../../i18n/ui';
import { localizePath, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Federal funding acknowledgment required alongside the BKA logo; both link to the same
// government page as in the sibling project. Logo swaps by locale (German/English wordmark).
const volksgruppenLink = 'https://www.bundeskanzleramt.gv.at/themen/volksgruppen.html';
const bkaLogo = lang === 'de' ? '/bka-logo-de.svg' : '/bka-logo-en.svg';
---

<footer class="site-footer">
	<div class="container footer-inner">
		<div class="footer-links">
			<a href={volksgruppenLink} target="_blank" rel="noopener" class="bka-logo-link">
				<img src={bkaLogo} alt={t('footer.minorityPromotion')} class="bka-logo" />
			</a>
			<a href={localizePath('/impressum', lang)}>{t('footer.imprint')}</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--color-border);
		margin-top: var(--space-5);
	}
	.footer-inner {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding-block: var(--space-3);
		color: var(--color-muted);
		font-size: 0.9em;
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3);
	}
	.footer-links a {
		color: var(--color-muted);
	}
	.footer-links a:hover {
		color: var(--color-text);
	}
	.bka-logo-link {
		display: inline-flex;
		align-items: center;
		line-height: 0;
	}
	.bka-logo {
		height: 2rem;
		width: auto;
	}
</style>

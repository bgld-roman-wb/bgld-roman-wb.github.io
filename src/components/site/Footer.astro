---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer style="border-top: 1px solid var(--color-border); margin-top: var(--space-5);">
	<div class="container" style="padding-block: var(--space-3); color: var(--color-muted); font-size: 0.9em;">
		<p>{t('footer.text')}</p>
	</div>
</footer>

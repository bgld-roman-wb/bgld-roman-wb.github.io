---
import BaseLayout from '../../layouts/BaseLayout.astro';
import abbreviations from '../../data/generated/abbreviations.json';
import { useTranslations, type Locale } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const lexRows = lang === 'de' ? abbreviations.lex.de : abbreviations.lex.en;
---

<BaseLayout title={t('abbr.title')} description={t('abbr.intro')} lang={lang}>
	<h1>{t('abbr.title')}</h1>
	<p>{t('abbr.intro')}</p>

	<section>
		<h2>{t('abbr.grammar')}</h2>
		<div class="table-scroll">
			<table>
				<thead>
					<tr>
						<th scope="col">{t('abbr.code')}</th>
						<th scope="col">{t('abbr.english')}</th>
						<th scope="col">{t('abbr.germanTechnical')}</th>
						<th scope="col">{t('abbr.germanPlain')}</th>
						<th scope="col">{t('abbr.roman')}</th>
					</tr>
				</thead>
				<tbody>
					{abbreviations.gram.map((row) => (
						<tr>
							<th scope="row">{row.code}</th>
							<td>{row.en}</td>
							<td>{row.de}</td>
							<td>{row.deLay}</td>
							<td>{row.roman}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</section>

	<section>
		<h2>{t('abbr.languages')}</h2>
		<div class="table-scroll">
			<table>
				<thead>
					<tr>
						<th scope="col">{t('abbr.code')}</th>
						<th scope="col">{t('abbr.iso')}</th>
						<th scope="col">{t('abbr.english')}</th>
						<th scope="col">{t('abbr.germanTechnical')}</th>
						<th scope="col">{t('abbr.roman')}</th>
					</tr>
				</thead>
				<tbody>
					{abbreviations.lang.map((row) => (
						<tr>
							<th scope="row">{row.code}</th>
							<td>{row.iso}</td>
							<td>{row.en}</td>
							<td>{row.de}</td>
							<td>{row.roman}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</section>

	<section>
		<h2>{t('abbr.lexicographic')}</h2>
		<div class="table-scroll">
			<table>
				<thead>
					<tr>
						<th scope="col">{t('abbr.code')}</th>
						<th scope="col">{t('abbr.meaning')}</th>
					</tr>
				</thead>
				<tbody>
					{lexRows.map((row) => (
						<tr>
							<th scope="row">{row.code}</th>
							<td>{row.expansion}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</section>
</BaseLayout>

<style>
	section {
		margin-block-start: var(--space-5);
	}
</style>

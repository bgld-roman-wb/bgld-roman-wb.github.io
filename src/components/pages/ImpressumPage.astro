---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Wordmark from '../site/Wordmark.astro';
import { useTranslations, type Locale } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Note: unlike the sibling romani-project.github.io Impressum, this project is not represented
// by Akademie Graz on behalf of Roma Service & Romano Centro — that institutional structure is
// specific to the sibling project and hasn't been confirmed for this one, so it's intentionally
// omitted here. Only the two people actually involved in this site are credited below.
---

<BaseLayout title={t('impressum.title')} lang={lang}>
	<p class="impressum-mark"><Wordmark /></p>
	<h1>{t('impressum.title')}</h1>
	<p>{t('impressum.copyright')}</p>
	<p>{t('impressum.content')}</p>
	<p>{t('impressum.technik')}</p>
</BaseLayout>

<style>
	.impressum-mark {
		font-size: 1.5rem;
		margin-bottom: var(--space-4);
	}
</style>

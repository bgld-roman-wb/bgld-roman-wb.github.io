---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LetterNav from '../browse/LetterNav.astro';
import Wordmark from '../site/Wordmark.astro';
import { allLetters, homeData } from '../../lib/collection';
import { glossFor, localizePath, useTranslations, type Locale } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const { count, familyCount, pool } = await homeData();
const letters = await allLetters();

// Word of the day: deterministic by calendar day. The build pre-renders today's pick; a small
// inline script re-picks on the visitor's device so the word still rotates between deploys.
const wotdPool = pool.map((d) => ({ slug: d.slug, word: d.lemma.deu, gloss: glossFor(d.glosses[0], lang) }));
const dayNumber = Math.floor(Date.now() / 86400000);
const wotd = wotdPool[dayNumber % wotdPool.length];
const entryPathPrefix = localizePath('/entry/', lang);
---

<BaseLayout title={t('site.title')} description={t('site.tagline')} lang={lang} searchIndex={false}>
	<section class="hero">
		<h1 class="hero-headword">
			<a href={localizePath('/entry/roman', lang)}><Wordmark /></a>
		</h1>
		<p class="hero-grammar">{t('home.langLine')}</p>
		<p class="hero-stats">
			{count.toLocaleString(lang)} {t('home.entriesLabel')} <span class="sep" aria-hidden="true">·</span> {familyCount.toLocaleString(lang)} {t('home.familiesLabel')}
		</p>
		<p class="hero-blurb">{t('home.blurb')}</p>
	</section>

	<section class="wotd" id="wotd">
		<p class="wotd-label">{t('home.wordOfDay')}</p>
		<p class="wotd-body">
			<a id="wotd-word" class="wotd-word" href={`${entryPathPrefix}${wotd.slug}`}>{wotd.word}</a>
			<span id="wotd-gloss" class="wotd-gloss">— {wotd.gloss}</span>
		</p>
	</section>

	<section class="letters">
		<LetterNav letters={letters} lang={lang} />
	</section>

	<p class="quick-links">
		<a href={localizePath('/about', lang)}>{t('home.about')}</a>
	</p>
</BaseLayout>

<script is:inline define:vars={{ wotdPool, entryPathPrefix }}>
	// Re-pick the word of the day on the visitor's clock (build-time pick goes stale between deploys).
	const dayNumber = Math.floor(Date.now() / 86400000);
	const pick = wotdPool[dayNumber % wotdPool.length];
	const word = document.getElementById('wotd-word');
	const gloss = document.getElementById('wotd-gloss');
	if (pick && word && word.textContent !== pick.word) {
		word.textContent = pick.word;
		word.setAttribute('href', entryPathPrefix + pick.slug);
		gloss.textContent = '— ' + pick.gloss;
	}
</script>

<style>
	.hero {
		text-align: center;
		padding-block: var(--space-5) var(--space-4);
	}
	.hero-headword {
		font-size: clamp(2.6rem, 8vw, 4rem);
		line-height: 1.1;
		margin: 0;
		letter-spacing: -0.01em;
	}
	.hero-headword a {
		color: inherit;
		text-decoration: none;
	}
	.hero-headword a:hover {
		color: var(--color-accent);
	}
	.hero-grammar {
		font-style: italic;
		color: var(--color-muted);
		margin: var(--space-1) 0 0;
		font-size: 1.05rem;
	}
	.hero-stats {
		color: var(--color-muted);
		font-size: 0.9rem;
		margin: var(--space-3) 0 0;
	}
	.hero-blurb {
		max-width: 34rem;
		margin: var(--space-3) auto 0;
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}
	.sep {
		margin: 0 0.4em;
		opacity: 0.55;
	}
	.wotd {
		max-width: 26rem;
		margin: var(--space-4) auto;
		padding: var(--space-3) var(--space-4);
		border: 1px solid var(--color-border);
		border-radius: 0.75rem;
		background: var(--color-surface);
		text-align: center;
	}
	.wotd-label {
		margin: 0 0 var(--space-1);
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-muted);
	}
	.wotd-body {
		margin: 0;
		font-size: 1.25rem;
	}
	.wotd-word {
		font-weight: 700;
		text-decoration: none;
	}
	.wotd-word:hover {
		text-decoration: underline;
	}
	.wotd-gloss {
		color: var(--color-muted);
		margin-inline-start: 0.35em;
	}
	.letters {
		display: flex;
		justify-content: center;
		margin-block-start: var(--space-4);
	}
	.letters :global(nav) {
		justify-content: center;
	}
	.quick-links {
		text-align: center;
		color: var(--color-muted);
		margin-block-start: var(--space-3);
	}
</style>

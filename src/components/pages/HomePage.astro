---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { entryCount } from '../../lib/collection';
import { localizePath, useTranslations, type Locale } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const count = await entryCount();
---

<BaseLayout title={t('site.title')} description={t('site.tagline')} lang={lang}>
	<h1>{t('site.title')}</h1>
	<p>{t('site.tagline')} — {count.toLocaleString(lang)} {t('home.intro.suffix')}</p>
	<p>
		<a href={localizePath('/browse/alphabetical/a', lang)}>{t('home.browseAlpha')}</a> ·
		<a href={localizePath('/browse', lang)}>{t('home.browseAll')}</a> ·
		<a href={localizePath('/about', lang)}>{t('home.about')}</a>
	</p>
</BaseLayout>

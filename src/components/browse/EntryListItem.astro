---
import type { Locale } from '../../i18n/ui';
import { glossFor, localizePath } from '../../i18n/ui';

interface Props {
	slug: string;
	lemma: { int: string; deu: string };
	glosses: { de: string | null; en: string | null }[];
	lang: Locale;
}

const { slug, lemma, glosses, lang } = Astro.props;
const firstGloss = glosses.map((g) => glossFor(g, lang)).find((g): g is string => Boolean(g));
---

<li>
	<a href={localizePath(`/entry/${slug}`, lang)}><strong>{lemma.int}</strong></a>
	{firstGloss && <span style="color: var(--color-muted);"> — {firstGloss}</span>}
</li>

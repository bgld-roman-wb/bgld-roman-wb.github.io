---
import type { Locale } from '../../i18n/ui';
import { localizePath } from '../../i18n/ui';

interface Props {
	letters: string[];
	current?: string;
	lang: Locale;
}

const { letters, current, lang } = Astro.props;
---

<nav aria-label="Alphabet" style="display: flex; flex-wrap: wrap; gap: var(--space-1); margin-block-end: var(--space-3);">
	{letters.map((letter) => (
		<a
			href={localizePath(`/browse/alphabetical/${letter}`, lang)}
			aria-current={letter === current ? 'page' : undefined}
			style={`padding: var(--space-1) var(--space-2); border: 1px solid var(--color-border); border-radius: 0.25rem; text-decoration: none; ${letter === current ? 'background: var(--color-accent); color: var(--color-accent-contrast); border-color: var(--color-accent);' : ''}`}
		>
			{letter.toUpperCase()}
		</a>
	))}
</nav>

---
import ParadigmTable from './ParadigmTable.astro';
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface ParadigmForm {
	label: (string | null)[];
	int?: string | null;
	deu?: string | null;
	intM?: string | null;
	intF?: string | null;
	deuM?: string | null;
	deuF?: string | null;
	german?: string | null;
	english?: string | null;
}

interface Props {
	paradigm: {
		kind: 'none' | 'exist' | 'gendered' | 'noun' | 'verb' | 'error';
		forms: ParadigmForm[];
	};
	lang: Locale;
}

const { paradigm, lang } = Astro.props;
const t = useTranslations(lang);
---

{paradigm.kind !== 'none' && (
	<details>
		<summary>{t('entry.paradigm')}</summary>
		<ParadigmTable kind={paradigm.kind} forms={paradigm.forms} lang={lang} />
	</details>
)}

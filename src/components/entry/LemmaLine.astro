---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface Pair {
	int: string | null;
	deu: string | null;
}

interface Props {
	lemma: { int: string; deu: string };
	composition: Pair | null;
	variation: Pair | null;
	reconstruction: Pair | null;
	lang: Locale;
}

const { lemma, composition, variation, reconstruction, lang } = Astro.props;
const t = useTranslations(lang);

// The source joins compound parts with "+"; render it spaced out ("ada + bérsch").
function compText(value: string | null | undefined): string | null {
	return value ? value.replace(/\s*\+\s*/g, ' + ') : null;
}

// Composition is shown inline in square brackets right after the word it belongs to, per
// orthography. The German-based (DEU) form sits by the headword; the international (INT) form only
// appears when it differs.
const compDeu = composition?.deu ?? composition?.int ?? null;
const compDeuText = compText(compDeu);
const showCompInt = Boolean(composition?.int && composition.int !== compDeu);
const compIntText = showCompInt ? compText(composition!.int) : null;

// The international line appears when either the spelling or its composition diverges from DEU.
const showInt = Boolean((lemma.int && lemma.int !== lemma.deu) || showCompInt);

// Variation and reconstruction aren't "parts of a word", so they stay as labeled text lines.
function pairText(pair: Pair | null) {
	const value = pair?.deu ?? pair?.int;
	return value ? value.replace(/\+/g, ' + ') : null;
}
// The source prefixes reconstructions with "<" ("derived from"); the label already says that, so
// drop the symbol and keep only the starred form. The star itself is explained in the hint.
function reconstructionText(pair: Pair | null) {
	const value = pairText(pair);
	return value ? value.replace(/^<\s*/, '') : null;
}
const lemmaDetails = [
	{ label: t('entry.variation'), hint: t('entry.variationHint'), value: pairText(variation) },
	{ label: t('entry.reconstruction'), hint: t('entry.reconstructionHint'), value: reconstructionText(reconstruction) },
].filter((item): item is { label: string; hint: string; value: string } => Boolean(item.value));
---

<div class="lemma">
	<h1 class="headword" data-pagefind-meta="title" data-pagefind-weight="10">
		<strong>{lemma.deu}</strong>
		{compDeuText && <span class="composition"> [{compDeuText}]</span>}
	</h1>
	{showInt && (
		<p class="int-spelling" data-pagefind-weight="8">
			<span class="tag hint-trigger" tabindex="0" data-hint={t('entry.intSpellingHint')} aria-label={t('entry.intSpellingHint')}>{t('entry.intSpelling')}</span>
			<span>
				{lemma.int}
				{compIntText && <span class="composition"> [{compIntText}]</span>}
			</span>
		</p>
	)}
	{lemmaDetails.length > 0 && (
		<dl class="lemma-details">
			{lemmaDetails.map((item) => (
				<div>
					<dt>
						<span class="detail-label hint-trigger" tabindex="0" data-hint={item.hint} aria-label={item.hint}>{item.label}</span>
					</dt>
					<dd>
						{item.value.startsWith('*') ? (
							<>
								<span class="star">*</span>{item.value.slice(1)}
							</>
						) : (
							item.value
						)}
					</dd>
				</div>
			))}
		</dl>
	)}
</div>

<style>
	.lemma {
		margin-block-end: var(--space-3);
	}
	.headword {
		font-size: 1.5rem;
		margin: 0;
		line-height: 1.2;
	}
	.composition {
		font-weight: 400;
		font-size: 0.72em;
		color: var(--color-muted);
		white-space: nowrap;
	}
	.int-spelling {
		margin: var(--space-1) 0 0;
		color: var(--color-muted);
		font-size: 0.95rem;
		display: flex;
		align-items: baseline;
		gap: var(--space-2);
	}
	.tag {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		border: 1px solid var(--color-border);
		border-radius: 0.25rem;
		padding: 0 var(--space-1);
		white-space: nowrap;
	}
	.lemma-details {
		margin: var(--space-2) 0 0;
		display: grid;
		gap: var(--space-1);
		color: var(--color-muted);
		font-size: 0.95rem;
	}
	.lemma-details div {
		display: grid;
		grid-template-columns: max-content minmax(0, 1fr);
		gap: var(--space-2);
	}
	.lemma-details dt {
		font-weight: 600;
	}
	/* The label itself is the hint trigger — a quiet dotted underline signals "tap/hover me",
	   matching the inflection-endings affordance, without adding a separate icon. */
	.detail-label {
		border-bottom: 1px dotted currentColor;
	}
	.lemma-details dd {
		margin: 0;
	}
	/* The reconstruction star (the linguists' "not in use" marker) gets a whisper of the accent
	   color so it reads as a deliberate symbol, not a typo. */
	.star {
		color: var(--color-accent);
		font-weight: 700;
	}
	@media (max-width: 36rem) {
		.lemma-details div {
			grid-template-columns: 1fr;
			gap: 0;
		}
	}
</style>

---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface Pair {
	int: string | null;
	deu: string | null;
}

interface Props {
	lemma: { int: string; deu: string };
	composition: Pair | null;
	variation: Pair | null;
	reconstruction: Pair | null;
	lang: Locale;
}

const { lemma, composition, variation, reconstruction, lang } = Astro.props;
const t = useTranslations(lang);

// The Roman headword is dictionary content with two orthographies (independent of app language):
// the German-based (DEU) spelling is the default/primary, the international (INT) spelling is
// secondary, shown on its own line only when it differs.
const showInt = lemma.int && lemma.int !== lemma.deu;

// Entry metadata follows the primary orthography (DEU), matching the headword.
function pairText(pair: Pair | null) {
	const value = pair?.deu ?? pair?.int;
	return value ? value.replace(/\+/g, ' + ') : null;
}

// Composition renders as chips (one per part), so split on the "+" join used in the source.
function compositionParts(value: string | null | undefined): string[] {
	return value ? value.split('+').map((p) => p.trim()).filter(Boolean) : [];
}
const compDeu = composition?.deu ?? composition?.int ?? null;
const compDeuParts = compositionParts(compDeu);
// The international composition is shown as a second chip row only when it actually differs.
const showCompInt = Boolean(composition?.int && composition.int !== compDeu);
const compIntParts = showCompInt ? compositionParts(composition!.int) : [];

// Variation and reconstruction aren't "parts of a word", so they stay as labeled text lines.
const lemmaDetails = [
	{ label: t('entry.variation'), value: pairText(variation) },
	{ label: t('entry.reconstruction'), value: pairText(reconstruction) },
].filter((item): item is { label: string; value: string } => Boolean(item.value));
---

<div class="lemma">
	<h1 class="headword" data-pagefind-meta="title" data-pagefind-weight="10">
		<strong>{lemma.deu}</strong>
	</h1>
	{showInt && (
		<p class="int-spelling" data-pagefind-weight="8">
			<span class="tag">{t('entry.intSpelling')}</span>
			<span>{lemma.int}</span>
		</p>
	)}
	{compDeuParts.length > 0 && (
		<div class="composition" aria-label={t('entry.composition')}>
			<div class="chips">
				{compDeuParts.map((part, i) => (
					<>
						{i > 0 && <span class="plus" aria-hidden="true">+</span>}
						<span class="chip">{part}</span>
					</>
				))}
			</div>
			{showCompInt && (
				<div class="chips chips-int">
					<span class="tag">{t('entry.intSpelling')}</span>
					{compIntParts.map((part, i) => (
						<>
							{i > 0 && <span class="plus" aria-hidden="true">+</span>}
							<span class="chip chip-muted">{part}</span>
						</>
					))}
				</div>
			)}
		</div>
	)}
	{lemmaDetails.length > 0 && (
		<dl class="lemma-details">
			{lemmaDetails.map((item) => (
				<div>
					<dt>{item.label}</dt>
					<dd>{item.value}</dd>
				</div>
			))}
		</dl>
	)}
</div>

<style>
	.lemma {
		margin-block-end: var(--space-3);
	}
	.headword {
		font-size: 1.5rem;
		margin: 0;
		line-height: 1.2;
	}
	.int-spelling {
		margin: var(--space-1) 0 0;
		color: var(--color-muted);
		font-size: 0.95rem;
		display: flex;
		align-items: baseline;
		gap: var(--space-2);
	}
	.tag {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		border: 1px solid var(--color-border);
		border-radius: 0.25rem;
		padding: 0 var(--space-1);
		white-space: nowrap;
	}
	.composition {
		margin: var(--space-2) 0 0;
	}
	.chips {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-1);
	}
	.chips + .chips {
		margin-top: var(--space-1);
	}
	.chip {
		display: inline-block;
		padding: 0.15rem var(--space-2);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.375rem;
		line-height: 1.3;
	}
	.chip-muted {
		background: transparent;
		color: var(--color-muted);
	}
	.plus {
		color: var(--color-muted);
	}
	.chips-int .tag {
		align-self: center;
	}
	.lemma-details {
		margin: var(--space-2) 0 0;
		display: grid;
		gap: var(--space-1);
		color: var(--color-muted);
		font-size: 0.95rem;
	}
	.lemma-details div {
		display: grid;
		grid-template-columns: max-content minmax(0, 1fr);
		gap: var(--space-2);
	}
	.lemma-details dt {
		font-weight: 600;
	}
	.lemma-details dd {
		margin: 0;
	}
	@media (max-width: 36rem) {
		.lemma-details div {
			grid-template-columns: 1fr;
			gap: 0;
		}
	}
</style>

---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface Pair {
	int: string | null;
	deu: string | null;
}

interface Props {
	lemma: { int: string; deu: string };
	composition: Pair | null;
	variation: Pair | null;
	reconstruction: Pair | null;
	lang: Locale;
}

const { lemma, composition, variation, reconstruction, lang } = Astro.props;
const t = useTranslations(lang);

// The Roman headword is dictionary content with two orthographies (independent of app language):
// the German-based (DEU) spelling is the default/primary, the international (INT) spelling is
// secondary, shown on its own line only when it differs.
const showInt = lemma.int && lemma.int !== lemma.deu;

// Bracketed extras (composition / variation / reconstruction) follow the primary orthography (DEU).
const bracketed = [composition, variation, reconstruction]
	.filter((p): p is Pair => p != null)
	.map((p) => p.deu ?? p.int ?? '')
	.filter(Boolean);
---

<div class="lemma">
	<p class="headword">
		<strong>{lemma.deu}</strong>
		{bracketed.length > 0 && <span class="brackets">[{bracketed.join('; ')}]</span>}
	</p>
	{showInt && (
		<p class="int-spelling">
			<span class="tag">{t('entry.intSpelling')}</span>
			<span>{lemma.int}</span>
		</p>
	)}
</div>

<style>
	.lemma {
		margin-block-end: var(--space-3);
	}
	.headword {
		font-size: 1.5rem;
		margin: 0;
	}
	.brackets {
		color: var(--color-muted);
		font-size: 0.6em;
		margin-inline-start: var(--space-1);
	}
	.int-spelling {
		margin: var(--space-1) 0 0;
		color: var(--color-muted);
		font-size: 0.95rem;
		display: flex;
		align-items: baseline;
		gap: var(--space-2);
	}
	.tag {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		border: 1px solid var(--color-border);
		border-radius: 0.25rem;
		padding: 0 var(--space-1);
		white-space: nowrap;
	}
</style>

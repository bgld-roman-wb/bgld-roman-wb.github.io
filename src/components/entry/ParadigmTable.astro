---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface ParadigmForm {
	label: (string | null)[];
	labelDisplay?: { code: string; de: string; en: string };
	int?: string | null;
	deu?: string | null;
	intM?: string | null;
	intF?: string | null;
	deuM?: string | null;
	deuF?: string | null;
	german?: string | null;
	english?: string | null;
}

interface Props {
	kind: 'none' | 'exist' | 'gendered' | 'noun' | 'verb' | 'error';
	forms: ParadigmForm[];
	lang: Locale;
}

const { kind, forms, lang } = Astro.props;
const t = useTranslations(lang);

function labelText(label: (string | null)[]) {
	return label.filter(Boolean).join(' ');
}

function displayLabel(form: ParadigmForm) {
	const fallback = labelText(form.label);
	return (lang === 'de' ? form.labelDisplay?.de : form.labelDisplay?.en) || fallback;
}

function codeLabel(form: ParadigmForm) {
	return form.labelDisplay?.code || labelText(form.label);
}
---

{kind === 'error' && <p class="data-unavailable">{t('entry.inflectionUnavailable')}</p>}

{kind === 'exist' && (
	<div class="table-scroll">
		<table>
			<thead>
				<tr><th scope="col">{t('table.form')}</th><th scope="col">Roman</th><th scope="col">{t('table.meaning')}</th></tr>
			</thead>
			<tbody>
				{forms.map((f) => (
					<tr>
						<th scope="row" title={codeLabel(f)}>{displayLabel(f)}</th>
						<td>{f.int}</td>
						<td>{lang === 'de' ? f.german : f.english}</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>
)}

{kind === 'gendered' && (
	<div class="table-scroll">
		<table>
			<thead>
				<tr><th scope="col">{t('table.form')}</th><th scope="col">DEU ({t('table.masc')})</th><th scope="col">DEU ({t('table.fem')})</th><th scope="col">INT ({t('table.masc')})</th><th scope="col">INT ({t('table.fem')})</th></tr>
			</thead>
			<tbody>
				{forms.map((f) => (
					<tr>
						<th scope="row" title={codeLabel(f)}>{displayLabel(f)}</th>
						<td>{f.deuM}</td>
						<td>{f.deuF}</td>
						<td>{f.intM}</td>
						<td>{f.intF}</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>
)}

{(kind === 'noun' || kind === 'verb') && (
	<div class="table-scroll">
		<table>
			<thead>
				<tr><th scope="col">{t('table.form')}</th><th scope="col">DEU</th><th scope="col">INT</th></tr>
			</thead>
			<tbody>
				{forms.map((f) => (
					<tr>
						<th scope="row" title={codeLabel(f)}>{displayLabel(f)}</th>
						<td>{f.deu}</td>
						<td>{f.int}</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>
)}

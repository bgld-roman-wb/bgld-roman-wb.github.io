---
import type { Locale } from '../../i18n/ui';
import { localizePath, useTranslations } from '../../i18n/ui';

interface Props {
	members: { slug: string; lemma: { int: string; deu: string } }[];
	base: { int: string | null; deu: string | null; slug: string | null; isSelf: boolean } | null;
	currentSlug: string;
	lang: Locale;
}

const { members, base, currentSlug, lang } = Astro.props;
const t = useTranslations(lang);
const showBaseBadge = base && !base.isSelf && base.slug && base.slug !== currentSlug;
---

<ul style="padding-inline-start: var(--space-4);">
	{showBaseBadge && (
		<li>
			<a href={localizePath(`/entry/${base!.slug}`, lang)}>{base!.int}</a> <span class="badge">{t('entry.baseWord')}</span>
		</li>
	)}
	{members.map((m) => (
		<li><a href={localizePath(`/entry/${m.slug}`, lang)}>{m.lemma.int}</a></li>
	))}
</ul>

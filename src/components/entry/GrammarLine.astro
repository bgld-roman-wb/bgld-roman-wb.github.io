---
import type { Locale } from '../../i18n/ui';
import { labelFor } from '../../i18n/ui';

interface GramLabel {
	code: string | null;
	en: string | null;
	de: string | null;
}
interface Pair {
	int: string | null;
	deu: string | null;
}

interface Props {
	class1: GramLabel;
	class2: GramLabel;
	flexion1: string | null;
	flexion2: Pair | null;
	flexion3: Pair | null;
	lang: Locale;
}

const { class1, class2, flexion1, flexion2, flexion3, lang } = Astro.props;

// Flexion markers are Roman morphemes (dictionary content) — show international (INT) form.
const flexParts = [flexion2, flexion3]
	.filter((p): p is Pair => p != null)
	.map((p) => p.int ?? p.deu ?? '')
	.filter(Boolean);
---

<p style="color: var(--color-muted);">
	{class1.code && <span title={class1.code}>{labelFor(class1, lang)}.</span>}
	{' '}
	{class2.code && <span title={class2.code}>{labelFor(class2, lang)}.</span>}
	{' '}
	{flexion1 && <span>{flexion1}</span>}
	{flexParts.length > 0 && <span>&nbsp;[{flexParts.join('; ')}]</span>}
</p>

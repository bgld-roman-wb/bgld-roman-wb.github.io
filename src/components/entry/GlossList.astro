---
import type { Locale } from '../../i18n/ui';
import { glossFor } from '../../i18n/ui';

interface Props {
	glosses: { de: string | null; en: string | null }[];
	lang: Locale;
}

const { glosses, lang } = Astro.props;

// Show only the meaning in the active app language — the two gloss languages are localizations of
// the same meaning, not to be shown together.
const localized = glosses.map((g) => glossFor(g, lang)).filter((g): g is string => Boolean(g));
---

{localized.length > 0 && (
	<ol style="padding-inline-start: var(--space-4);">
		{localized.map((gloss) => <li>{gloss}</li>)}
	</ol>
)}

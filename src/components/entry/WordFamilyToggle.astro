---
import WordFamilyList from './WordFamilyList.astro';
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface Props {
	wordFamily: { slug: string; lemma: { int: string; deu: string }; glosses: { de: string | null; en: string | null }[] }[];
	base: {
		int: string | null;
		deu: string | null;
		slug: string | null;
		isSelf: boolean;
		glosses: { de: string | null; en: string | null }[];
	} | null;
	currentSlug: string;
	lang: Locale;
}

const { wordFamily, base, currentSlug, lang } = Astro.props;
const t = useTranslations(lang);
const hasBaseLink = base && !base.isSelf && base.slug && base.slug !== currentSlug;
const hasContent = wordFamily.length > 0 || hasBaseLink;
---

{hasContent && (
	<details data-pagefind-weight="0.75">
		<summary data-pagefind-ignore>{t('entry.wordFamily')}</summary>
		<WordFamilyList members={wordFamily} base={base} currentSlug={currentSlug} lang={lang} />
	</details>
)}

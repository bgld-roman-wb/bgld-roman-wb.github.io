---
import type { Locale } from '../../i18n/ui';
import { labelFor, localizePath, useTranslations } from '../../i18n/ui';

interface Pair {
	int: string | null;
	deu: string | null;
}

interface Props {
	source: {
		code: string | null;
		isDerivation: boolean;
		label: { en: string | null; de: string | null } | null;
		foreignForm: Pair | null;
		derivationBase: Pair | null;
		derivationSlug: string | null;
	};
	lang: Locale;
}

const { source, lang } = Astro.props;
const t = useTranslations(lang);

const sourceLabel = labelFor(source.label, lang) ?? source.code;
const foreignForm = source.foreignForm?.deu ?? source.foreignForm?.int;
const derivationBase = source.derivationBase?.deu ?? source.derivationBase?.int ?? t('entry.derivedFromBase');

function germanEtymologyName(label: string) {
	const match = label.match(/^(.*?)(\s*\(.*\))?$/);
	const base = match?.[1]?.trim() ?? label;
	const note = match?.[2] ?? '';
	if (base.endsWith('sch')) return `${base}en${note}`;
	return `${base}${note}`;
}

function etymologySentence() {
	if (!sourceLabel) return null;
	if (source.code === 'etym?') return sourceLabel;
	if (lang === 'de') {
		const form = foreignForm ? ` (${foreignForm})` : '';
		return `${t('entry.sourceFrom')} ${germanEtymologyName(sourceLabel)}${form}`;
	}
	return `${t('entry.sourceFrom')} ${sourceLabel}${foreignForm ? ` ${foreignForm}` : ''}`;
}
---

{source.code && (
	<p style="font-size: 0.9em; color: var(--color-muted);" data-pagefind-weight="0.5">
		{source.isDerivation ? (
			<>
				{t('entry.derivedFrom')}{' '}
				{source.derivationSlug ? (
					<a href={localizePath(`/entry/${source.derivationSlug}`, lang)}>{derivationBase}</a>
				) : (
					<span>{derivationBase}</span>
				)}
			</>
		) : (
			<>{etymologySentence()}</>
		)}
	</p>
)}

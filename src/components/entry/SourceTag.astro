---
import type { Locale } from '../../i18n/ui';
import { labelFor, localizePath, useTranslations } from '../../i18n/ui';

interface Pair {
	int: string | null;
	deu: string | null;
}

interface Props {
	source: {
		code: string | null;
		isDerivation: boolean;
		label: { en: string | null; de: string | null } | null;
		foreignForm: Pair | null;
		derivationSlug: string | null;
	};
	lang: Locale;
}

const { source, lang } = Astro.props;
const t = useTranslations(lang);
---

{source.code && (
	<p style="font-size: 0.9em; color: var(--color-muted);">
		{source.isDerivation ? (
			<>
				{t('entry.derivedFrom')}{' '}
				{source.derivationSlug ? (
					<a href={localizePath(`/entry/${source.derivationSlug}`, lang)}>{t('entry.derivedFromBase')}</a>
				) : (
					<span>{t('entry.derivedFromBase')}</span>
				)}
			</>
		) : (
			<>
				{labelFor(source.label, lang) ?? source.code}
				{source.foreignForm?.int && <> — {source.foreignForm.int}</>}
			</>
		)}
	</p>
)}
